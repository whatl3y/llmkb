# LLM Provider: "claude" or "openai"
LLM_PROVIDER=claude

# Claude API (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
# Model override — default: claude-sonnet-4-20250514
#   Budget:  claude-haiku-4-5-20251001  (~$0.25/$1.25 per MTok in/out — fast, good at structured output)
#   Balance: claude-sonnet-4-20250514   (~$3/$15 per MTok — default, strong synthesis)
#   Max:     claude-opus-4-20250514     (~$15/$75 per MTok — best reasoning, highest cost)
CLAUDE_MODEL=

# OpenAI API (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=
# Model override — default: gpt-4o
#   Budget:  gpt-4o-mini  (~$0.15/$0.60 per MTok in/out — fast, good at structured output)
#   Balance: gpt-4o       (~$2.50/$10 per MTok — default, strong all-around)
#   Max:     o3-mini      (~$1.10/$4.40 per MTok — best reasoning, slower)
OPENAI_MODEL=

# ChromaDB
# For Chroma Cloud: set API_KEY and TENANT (uses CloudClient automatically)
#CHROMA_API_KEY=
#CHROMA_TENANT=
#CHROMA_DATABASE=
# For local/self-hosted: leave API_KEY blank, set URL instead
CHROMA_URL=http://localhost:8930
#CHROMA_TOKEN=

# Storage backend: "filesystem" (default) or "database" (Postgres + S3)
# filesystem: all data in local DATA_DIR/ (no external deps beyond ChromaDB)
# database:   wiki pages + metadata in Postgres, uploads in S3
STORAGE_BACKEND=filesystem

# Data directory — used by filesystem backend
DATA_DIR=./data

# PostgreSQL (required when STORAGE_BACKEND=database)
# For local dev: npm run migrate
# In Docker:     migrations run automatically on container start
#DATABASE_URL=postgres://llmkb:llmkb@localhost:5433/llmkb

# AWS S3 (required when STORAGE_BACKEND=database, for storing uploaded source files)
# Credentials are optional — falls back to IAM roles/instance profiles if unset
#AWS_BUCKET=llmkb-uploads
#AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=

# Server
PORT=3000

# File watcher: set to "false" to disable auto-ingestion
WATCH_RAW=true

# Auth (optional — leave blank or AUTH_ENABLED=false to run without auth)
# When enabled, only whitelisted users (in data/auth/users.json) can ingest content.
# Read access (search, query, browse) is always open.
AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Secret key for signing JWT session tokens (32+ random bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Base URL for OAuth callback (default: http://localhost:<PORT>)
HOST=http://localhost:3000

{
  "name": "llm-kb-personal",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite dev",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:test": "docker compose --profile test run --rm test",
    "setup": "tsx scripts/setup.ts",
    "add-user": "tsx scripts/add-user.ts",
    "migrate": "tsx src/database/migrate.ts",
    "migrate-data": "tsx scripts/migrate-data.ts",
    "create": "./create-kb.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/lib-storage": "^3.1029.0",
    "@types/cookie-parser": "^1.4.10",
    "arctic": "^3.7.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.0",
    "chromadb": "^1.9.2",
    "chromadb-default-embed": "^2.14.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "mammoth": "^1.12.0",
    "marked": "^15.0.0",
    "multer": "^1.4.5-lts.1",
    "officeparser": "^6.0.7",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pptx-parser": "^1.1.7-beta.9",
    "tsx": "^4.19.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
